# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=slottet_db
DB_USER=root
DB_PASSWORD=

# Connection String (alternative)
# ConnectionStrings__DefaultConnection=Server=localhost;Database=slottet_db;User Id=root;Password=;

# Application Settings
ASPNETCORE_ENVIRONMENT=Development
ASPNETCORE_URLS=http://+:5000;https://+:5001

# API Settings
API_BASE_URL=http://localhost:5000

# Blazor Settings
BLAZOR_BASE_URL=http://localhost:5002

# JWT/Authentication (hvis nødvendigt)
JWT_SECRET=your-secret-key-here
JWT_ISSUER=Slottet.Api
JWT_AUDIENCE=Slottet.BlazorApp
JWT_EXPIRATION_MINUTES=60

# CORS Settings
ALLOWED_ORIGINS=http://localhost:5002,https://localhost:5003

# Cloud/Docker Settings
ENABLE_DOCKER=false
ENABLE_LOAD_BALANCING=false

# Logging
LOG_LEVEL=Information
