# ============================================================
# Slottet - Environment Variables Template
# Copy this file to .env and fill in your values.
# .env is git-ignored and must never be committed.
# ============================================================

# --- Database ---
DB_HOST=
DB_PORT=3306
DB_NAME=slottet
DB_USER=
DB_PASSWORD=

# --- JWT ---
# Must be at least 32 characters. Use a strong random string in production.
Jwt__Key=
Jwt__Issuer=SlottetApi
Jwt__Audience=SlottetBlazor

# --- CORS ---
# Comma-separated list of allowed Blazor frontend origins.
# In production, set this to the public URL of the Blazor app.
BLAZOR_ORIGIN=http://localhost:5140,http://localhost:5050

# --- Ports (used by docker-compose) ---
API_PORT=5000
BLAZOR_PORT=5050
