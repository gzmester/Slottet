@{
    ViewData["Title"] = "Om Slottet";
}

<h1>@ViewData["Title"]</h1>

<div class="row mt-4">
    <div class="col-md-8">
        <h3>Om Systemet</h3>
        <p>
            Slottet er et moderne plejehjemssystem bygget med ASP.NET Core MVC.
            Systemet understøtter:
        </p>
        <ul>
            <li>Beboerhåndtering med komplet information</li>
            <li>Medicinering og logging</li>
            <li>RESTful API til eksterne integrationer</li>
            <li>Cloud-ready arkitektur</li>
            <li>Docker support</li>
        </ul>

        <h3 class="mt-4">Teknologi Stack</h3>
        <ul>
            <li><strong>Framework:</strong> ASP.NET Core 8.0 MVC</li>
            <li><strong>Database:</strong> Entity Framework Core + SQL Server</li>
            <li><strong>Frontend:</strong> Razor Views + Bootstrap 5</li>
            <li><strong>API:</strong> RESTful Web API med Swagger</li>
            <li><strong>Containerisering:</strong> Docker</li>
        </ul>

        <h3 class="mt-4">Fremtidige Features</h3>
        <ul>
            <li>Integration med Fælles Medicinkort (FMK)</li>
            <li>Notifikationer og påmindelser</li>
            <li>Rapportering og analytics</li>
            <li>Autentifikation og roller</li>
        </ul>
    </div>

    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>Projekt Info</h5>
            </div>
            <div class="card-body">
                <p><strong>Version:</strong> 1.0.0</p>
                <p><strong>Udviklet:</strong> 2026</p>
                <p><strong>Type:</strong> Eksamensprojekt</p>
            </div>
        </div>
    </div>
</div>
