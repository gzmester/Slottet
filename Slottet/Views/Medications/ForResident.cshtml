@model IEnumerable<Slottet.Models.Medication>

@{
    ViewData["Title"] = "Medicin for " + ViewBag.ResidentName;
    var residentId = (int)ViewBag.ResidentId;
    var residentName = (string)ViewBag.ResidentName;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1>Medicin</h1>
        <p class="text-muted">For: <strong>@residentName</strong></p>
    </div>
    <div>
        <a asp-action="Create" asp-route-residentId="@residentId" class="btn btn-success">
            ➕ Tilføj Medicin
        </a>
        <a asp-controller="Residents" asp-action="Details" asp-route-id="@residentId" class="btn btn-secondary">
            ← Tilbage til beboer
        </a>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert alert-warning">
        <h4>Ingen medicin fundet</h4>
        <p>Denne beboer har ingen registreret medicin.</p>
        <a asp-action="Create" asp-route-residentId="@residentId" class="btn btn-primary mt-2">
            Tilføj første medicin
        </a>
    </div>
}
else
{
    <div class="row">
        @foreach (var medication in Model)
        {
            <div class="col-md-6 mb-3">
                <div class="card @(!medication.IsActive ? "border-secondary" : "")">
                    <div class="card-header @(!medication.IsActive ? "bg-secondary text-white" : "bg-primary text-white")">
                        <h5 class="mb-0">
                            💊 @medication.Name
                            @if (!medication.IsActive)
                            {
                                <span class="badge bg-light text-dark float-end">Inaktiv</span>
                            }
                        </h5>
                    </div>
                    <div class="card-body">
                        <dl class="row mb-0">
                            <dt class="col-sm-4">Dosering:</dt>
                            <dd class="col-sm-8">@medication.Dosage</dd>
                            
                            <dt class="col-sm-4">Frekvens:</dt>
                            <dd class="col-sm-8">@medication.Frequency</dd>
                            
                            @if (!string.IsNullOrEmpty(medication.Instructions))
                            {
                                <dt class="col-sm-4">Instruktioner:</dt>
                                <dd class="col-sm-8">
                                    <small>@medication.Instructions</small>
                                </dd>
                            }
                            
                            <dt class="col-sm-4">Start:</dt>
                            <dd class="col-sm-8">@medication.StartDate.ToShortDateString()</dd>
                            
                            @if (medication.EndDate.HasValue)
                            {
                                <dt class="col-sm-4">Slut:</dt>
                                <dd class="col-sm-8">@medication.EndDate.Value.ToShortDateString()</dd>
                            }
                        </dl>
                        
                        @if (medication.Logs.Any())
                        {
                            var lastLog = medication.Logs.OrderByDescending(l => l.AdministeredAt).First();
                            <div class="alert alert-info mt-2 mb-0">
                                <small>
                                    <strong>Sidst givet:</strong> @lastLog.AdministeredAt.ToString("dd/MM/yyyy HH:mm")
                                </small>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        <div class="btn-group" role="group">
                            @if (medication.IsActive)
                            {
                                <a asp-action="LogAdministration" asp-route-id="@medication.Id" class="btn btn-sm btn-success">
                                    ✅ Log Givet
                                </a>
                            }
                            <button class="btn btn-sm btn-info" onclick="alert('Redigering kommer snart')">
                                ✏️ Rediger
                            </button>
                            <button class="btn btn-sm btn-secondary" onclick="alert('Historik kommer snart')">
                                📋 Historik
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

