@model Slottet.Models.Medication

@{
    ViewData["Title"] = "Tilføj Medicin";
    var residentName = (string)ViewBag.ResidentName;
}

<h1>Tilføj Medicin</h1>
<p class="text-muted">For: <strong>@residentName</strong></p>

<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <input type="hidden" asp-for="ResidentId" />
            
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="fx Panodil, Ipren, etc." />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="Dosage" class="form-label"></label>
                    <input asp-for="Dosage" class="form-control" placeholder="fx 500mg, 1 tablet" />
                    <span asp-validation-for="Dosage" class="text-danger"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="Frequency" class="form-label"></label>
                    <input asp-for="Frequency" class="form-control" placeholder="fx 2x dagligt, hver 8. time" />
                    <span asp-validation-for="Frequency" class="text-danger"></span>
                </div>
            </div>
            
            <div class="mb-3">
                <label asp-for="Instructions" class="form-label"></label>
                <textarea asp-for="Instructions" class="form-control" rows="3" placeholder="Tages med mad, før sengetid, etc."></textarea>
                <span asp-validation-for="Instructions" class="text-danger"></span>
            </div>
            
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label asp-for="StartDate" class="form-label"></label>
                    <input asp-for="StartDate" class="form-control" type="date" />
                    <span asp-validation-for="StartDate" class="text-danger"></span>
                </div>
                
                <div class="col-md-6 mb-3">
                    <label asp-for="EndDate" class="form-label"></label>
                    <input asp-for="EndDate" class="form-control" type="date" />
                    <span asp-validation-for="EndDate" class="text-danger"></span>
                    <small class="form-text text-muted">Efterlad tom hvis medicinen er permanent</small>
                </div>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" checked />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-success">💊 Gem Medicin</button>
                <a asp-action="ForResident" asp-route-id="@Model.ResidentId" class="btn btn-secondary">Annuller</a>
            </div>
        </form>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>💡 Hjælp</h5>
            </div>
            <div class="card-body">
                <h6>Eksempler på frekvens:</h6>
                <ul class="small">
                    <li>1x dagligt (morgen)</li>
                    <li>2x dagligt (morgen & aften)</li>
                    <li>3x dagligt (til måltider)</li>
                    <li>Hver 6. time</li>
                    <li>Ved behov</li>
                </ul>
                
                <h6 class="mt-3">Tips:</h6>
                <p class="small">
                    Vær så specifik som muligt med instruktioner for at undgå fejl.
                </p>
            </div>
        </div>
        
        <div class="card mt-3">
            <div class="card-header">
                <h5>⚠️ Husk</h5>
            </div>
            <div class="card-body">
                <p class="small">
                    Efter oprettelse skal medicinen logges hver gang den gives til beboeren.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    @*
    EKSEMPLER PÅ VALIDERING OG AUTO-COMPLETE:
    
