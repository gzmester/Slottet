@model Slottet.Models.Resident

@{
    ViewData["Title"] = "Opret Beboer";
}

<h1>Opret Ny Beboer</h1>

<hr />

<div class="row">
    <div class="col-md-8">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="mb-3">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" placeholder="Indtast fulde navn" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="CPR" class="form-label"></label>
                <input asp-for="CPR" class="form-control" placeholder="DDMMYYXXXX" maxlength="10" />
                <span asp-validation-for="CPR" class="text-danger"></span>
                <small class="form-text text-muted">Format: DDMMYYXXXX (valgfrit)</small>
            </div>
            
            <div class="mb-3">
                <label asp-for="DateOfBirth" class="form-label"></label>
                <input asp-for="DateOfBirth" class="form-control" type="date" />
                <span asp-validation-for="DateOfBirth" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="RoomNumber" class="form-label"></label>
                <input asp-for="RoomNumber" class="form-control" placeholder="fx 101, A-12, etc." />
                <span asp-validation-for="RoomNumber" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="AdmissionDate" class="form-label"></label>
                <input asp-for="AdmissionDate" class="form-control" type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="AdmissionDate" class="text-danger"></span>
            </div>
            
            <div class="mb-3">
                <label asp-for="MedicalNotes" class="form-label"></label>
                <textarea asp-for="MedicalNotes" class="form-control" rows="4" placeholder="Allergier, specielle forhold, etc."></textarea>
                <span asp-validation-for="MedicalNotes" class="text-danger"></span>
            </div>
            
            <div class="mb-3 form-check">
                <input asp-for="IsActive" class="form-check-input" checked />
                <label asp-for="IsActive" class="form-check-label"></label>
            </div>
            
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Gem Beboer</button>
                <a asp-action="Index" class="btn btn-secondary">Annuller</a>
            </div>
        </form>
    </div>
    
    <div class="col-md-4">
        <div class="card">
            <div class="card-header">
                <h5>💡 Hjælp</h5>
            </div>
            <div class="card-body">
                <h6>Påkrævede felter:</h6>
                <ul>
                    <li>Navn</li>
                    <li>Fødselsdato</li>
                    <li>Indflytningsdato</li>
                </ul>
                
                <h6 class="mt-3">Tips:</h6>
                <p class="small">
                    CPR-nummer er valgfrit, men anbefales for integration med FMK.
                </p>
                <p class="small">
                    Medicinske noter vises som advarsler på beboerens side.
                </p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
