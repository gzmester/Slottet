@inherits LayoutComponentBase

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <header class="header">
            <input type="date" value="@DateTime.Today.ToString("yyyy-MM-dd")" class="form-control header-date-input" readonly />
            <LoginHeader />
        </header>

        <article class="content px-4">
            @Body
        </article>
    </main>

    <footer class="footer-container-flex footer">
        <h2 class="footer-text-box">HUSK Risiko vurdering</h2>
        <h2 class="footer-text-box">HUSK Medicin</h2>
        <h2 class="footer-text-box">HUSK Sundhedsplanner</h2>
        <h2 class="footer-text-box">HUSK Delmål</h2>
    </footer>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
