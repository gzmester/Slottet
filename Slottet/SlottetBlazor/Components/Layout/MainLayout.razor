@inherits LayoutComponentBase
@using Microsoft.AspNetCore.Components.Authorization
@using SlottetBlazor.Services

@inject HttpClient Http
@inject AuthenticationStateProvider AuthStateProvider

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row px-4">
            <AuthorizeView>
                <Authorized>
                    <span class="me-3">Welcome, @context.User.Identity?.Name!</span>
                    <button class="btn btn-outline-danger btn-sm" @onclick="HandleLogout">Logout</button>
                </Authorized>
                <NotAuthorized>
                    @* The Login Form *@
                    <div class="d-flex align-items-center gap-2">
                        <input type="text" placeholder="Username" @bind="loginModel.Username" class="form-control form-control-sm" />
                        <input type="password" placeholder="Password" @bind="loginModel.Password" class="form-control form-control-sm" />
                        <button class="btn btn-primary btn-sm" @onclick="HandleLogin">Login</button>
                    </div>
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private LoginRequest loginModel = new();

    private async Task HandleLogin()
    {
        // 1. Send the login request to your API
        // Make sure your AuthController has a [HttpPost("login")] endpoint
        var response = await Http.PostAsJsonAsync("api/auth/login", loginModel);

        if (response.IsSuccessStatusCode)
        {
            var result = await response.Content.ReadFromJsonAsync<LoginResult>();
            
            if (result != null && !string.IsNullOrEmpty(result.Token))
            {
                // 2. Notify your custom state provider about the new token
                var customAuthStateProvider = (ApiAuthenticationStateProvider)AuthStateProvider;
                await customAuthStateProvider.MarkUserAsAuthenticated(result.Token);

                // 3. Reset form and refresh
                loginModel = new();
            }
        }
        else
        {
            // Handle login failure (e.g., show an alert)
            Console.WriteLine("Login failed.");
        }
    }

    private async Task HandleLogout()
    {
        var customAuthStateProvider = (ApiAuthenticationStateProvider)AuthStateProvider;
        await customAuthStateProvider.MarkUserAsLoggedOut();
    }

    // Helper classes for binding
    public class LoginRequest { 
        public string Username { get; set; } = string.Empty; 
        public string Password { get; set; } = string.Empty; 
    }
    public class LoginResult { 
        public string Token { get; set; } = string.Empty; 
    }
}