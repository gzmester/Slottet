@rendermode InteractiveServer

@using SlottetBlazor.Services
@using System.Text.Json
@using System.Net.Http.Json
@using Domain.Enums

@inject IHttpClientFactory HttpClientFactory
@inject IJSRuntime JS

<div class="header-right">
    @if (isLoggedIn)
    {
        <span class="badge bg-light text-dark me-2" style="font-size: 14px;">@userDisplayName</span>
        @if (isAdmin)
        {
            <span class="badge bg-danger me-2">Admin</span>
        }
        @if (isVagtansvarlig)
        {
            <span class="badge bg-warning text-dark me-2">Vagtansvarlig</span>
        }

        @* Vagttype-vælger *@
        <div class="btn-group me-2" role="group" aria-label="Vagttype">
            <button type="button" class="btn btn-sm @(selectedShiftType == ShiftType.Day ? "btn-success active" : "btn-light")"
                    @onclick="() => SelectShiftType(ShiftType.Day)" title="Dagvagt" style="font-size: 13px;">
                ☀️ Dag
            </button>
            <button type="button" class="btn btn-sm @(selectedShiftType == ShiftType.Midday ? "btn-warning active" : "btn-light")"
                    @onclick="() => SelectShiftType(ShiftType.Midday)" title="Aftenvagt" style="font-size: 13px;">
                🌅 Aften
            </button>
            <button type="button" class="btn btn-sm @(selectedShiftType == ShiftType.Night ? "btn-dark active" : "btn-light")"
                    @onclick="() => SelectShiftType(ShiftType.Night)" title="Nattevagt" style="font-size: 13px;">
                🌙 Nat
            </button>
        </div>

        <button class="btn btn-sm btn-danger" @onclick="OnLogoutClick" style="font-size: 13px;">
            Log ud
        </button>
    }
    else
    {
        <div style="display: flex; align-items: center; gap: 5px;">
            <input class="form-control" type="email" placeholder="Email" @bind="loginEmail"
                   style="width: 180px; height: 32px; font-size: 13px;"
                   @onkeyup="OnEmailKeyUp" />
            <input class="form-control" type="password" placeholder="Pinkode"
                   maxlength="6" @bind="pincode" @onkeyup="OnPincodeKeyUp"
                   style="width: 100px; height: 32px; font-size: 13px;" />
            <button class="btn btn-primary" style="height: 32px; font-size: 13px;"
                    @onclick="OnLoginClick" disabled="@isLoggingIn">
                @(isLoggingIn ? "..." : "Log ind")
            </button>
        </div>
    }
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div style="color: red; margin-left: 10px; font-size: 12px;">@errorMessage</div>
    }
</div>

@* Setup Pincode Modal *@
@if (showSetupModal)
{
    <div class="modal d-block" tabindex="-1" style="background: rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Opret Pinkode</h5>
                </div>
                <div class="modal-body">
                    <p>Velkommen, <strong>@setupEmployeeName</strong>! Du skal oprette en pinkode for at fortsætte.</p>
                    <div class="mb-3">
                        <label class="form-label">Ny pinkode (4-6 cifre)</label>
                        <input type="password" class="form-control" maxlength="6" @bind="setupPincode" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Bekræft pinkode</label>
                        <input type="password" class="form-control" maxlength="6" @bind="setupPincodeConfirm" />
                    </div>
                    @if (!string.IsNullOrEmpty(setupError))
                    {
                        <div class="alert alert-danger">@setupError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button class="btn btn-primary" @onclick="OnSetupPincode" disabled="@isSettingUp">
                        @(isSettingUp ? "Opretter..." : "Opret pinkode")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoggedIn = false;
    private bool isAdmin = false;
    private bool isVagtansvarlig = false;
    private string userDisplayName = "";
    private ShiftType? selectedShiftType = null;
    private bool isSavingShift = false;

    private string loginEmail = "";
    private string pincode = "";
    private string errorMessage = "";
    private bool isLoggingIn = false;

    private bool showSetupModal = false;
    private int setupEmployeeId;
    private string setupEmployeeName = "";
    private string setupPincode = "";
    private string setupPincodeConfirm = "";
    private string setupError = "";
    private bool isSettingUp = false;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await ReadTokenFromStorage();
    }

    private async Task ReadTokenFromStorage()
    {
        try
        {
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
            {
                var claims = ParseClaimsFromJwt(token);
                isLoggedIn = true;
                isAdmin = claims.Any(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" && c.Value == "Admin");
                isVagtansvarlig = claims.Any(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" && c.Value == "Vagtansvarlig");
                userDisplayName = claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value ?? "Bruger";

                // Læs ShiftType fra JWT
                var shiftClaim = claims.FirstOrDefault(c => c.Type == "ShiftType");
                if (shiftClaim != null && Enum.TryParse<ShiftType>(shiftClaim.Value, out var parsedShift))
                    selectedShiftType = parsedShift;

                StateHasChanged();
            }
        }
        catch { /* JS ikke klar endnu */ }
    }

    private async Task OnLoginClick()
    {
        if (string.IsNullOrWhiteSpace(loginEmail))
        { errorMessage = "Indtast email"; return; }
        if (string.IsNullOrWhiteSpace(pincode) || pincode.Length < 4)
        { errorMessage = "Pinkode skal være mindst 4 cifre"; return; }

        isLoggingIn = true;
        errorMessage = "";

        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var response = await http.PostAsJsonAsync("/api/auth/login", new { email = loginEmail, pincode = pincode });

            if (response.IsSuccessStatusCode)
            {
                var content = await response.Content.ReadAsStringAsync();
                using var doc = JsonDocument.Parse(content);
                var root = doc.RootElement;

                if (root.TryGetProperty("requiresSetup", out var requiresSetup) && requiresSetup.GetBoolean())
                {
                    setupEmployeeId = root.GetProperty("employeeId").GetInt32();
                    setupEmployeeName = root.GetProperty("employeeName").GetString() ?? "Bruger";
                    showSetupModal = true;
                    pincode = "";
                    isLoggingIn = false;
                    return;
                }

                var token = root.GetProperty("token").GetString();
                var employeeName = root.GetProperty("employeeName").GetString();

                if (token != null)
                {
                    // Gem token i localStorage (simpelt, som JavaScript)
                    await JS.InvokeVoidAsync("localStorage.setItem", "authToken", token);

                    // Afkod roller direkte fra JWT
                    var claims = ParseClaimsFromJwt(token);
                    isLoggedIn = true;
                    isAdmin = claims.Any(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" && c.Value == "Admin");
                    isVagtansvarlig = claims.Any(c => c.Type == "http://schemas.microsoft.com/ws/2008/06/identity/claims/role" && c.Value == "Vagtansvarlig");
                    userDisplayName = employeeName ?? claims.FirstOrDefault(c => c.Type == "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/name")?.Value ?? "Bruger";

                    // Læs ShiftType fra JWT
                    var shiftClaim = claims.FirstOrDefault(c => c.Type == "ShiftType");
                    if (shiftClaim != null && Enum.TryParse<ShiftType>(shiftClaim.Value, out var parsedShift))
                    selectedShiftType = parsedShift;

                    // Fallback: læs CurrentShiftType fra login-svar
                    if (selectedShiftType == null && root.TryGetProperty("currentShiftType", out var shiftTypeProp))
                    {
                        var shiftTypeStr = shiftTypeProp.GetString();
                        if (!string.IsNullOrEmpty(shiftTypeStr) && Enum.TryParse<ShiftType>(shiftTypeStr, out var parsedShift2))
                            selectedShiftType = parsedShift2;
                    }

                    // Endelig fallback: hent fra API
                    if (selectedShiftType == null)
                    {
                        try
                        {
                            var shiftHttp = HttpClientFactory.CreateClient("API");
                            shiftHttp.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                            var shiftResp = await shiftHttp.GetAsync("api/shifts/today");
                            if (shiftResp.IsSuccessStatusCode)
                            {
                                var shiftJson = await shiftResp.Content.ReadAsStringAsync();
                                using var shiftDoc = JsonDocument.Parse(shiftJson);
                                if (shiftDoc.RootElement.TryGetProperty("shiftType", out var stProp) && stProp.ValueKind != JsonValueKind.Null)
                                {
                                    var stStr = stProp.GetString();
                                    if (!string.IsNullOrEmpty(stStr) && Enum.TryParse<ShiftType>(stStr, out var parsedShift3))
                                        selectedShiftType = parsedShift3;
                                }
                            }
                        }
                        catch { }
                    }

                    pincode = "";
                    loginEmail = "";
                    errorMessage = "";
                }
                else
                {
                    errorMessage = "Login fejl: Intet token modtaget";
                }
            }
            else
            {
                errorMessage = "Forkert email eller pinkode";
            }
        }
        catch (Exception ex)
        {
            errorMessage = "Fejl ved login: " + ex.Message;
        }
        finally
        {
            isLoggingIn = false;
        }
    }

    private async Task OnSetupPincode()
    {
        setupError = "";
        if (string.IsNullOrWhiteSpace(setupPincode) || setupPincode.Length < 4)
        { setupError = "Pinkode skal være mindst 4 cifre"; return; }
        if (setupPincode != setupPincodeConfirm)
        { setupError = "Pinkoder matcher ikke"; return; }

        isSettingUp = true;
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var response = await http.PostAsJsonAsync("/api/auth/setup-pincode", new { employeeId = setupEmployeeId, pincode = setupPincode });
            if (response.IsSuccessStatusCode)
            {
                showSetupModal = false;
                pincode = setupPincode;
                await OnLoginClick();
            }
            else
            {
                setupError = $"Fejl ved oprettelse: {response.StatusCode}";
            }
        }
        catch (Exception ex) { setupError = "Fejl: " + ex.Message; }
        finally { isSettingUp = false; }
    }

    private async Task SelectShiftType(ShiftType shiftType)
    {
        if (isSavingShift) return;
        selectedShiftType = shiftType;
        isSavingShift = true;
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var token = await JS.InvokeAsync<string?>("localStorage.getItem", "authToken");
            if (!string.IsNullOrEmpty(token))
                http.DefaultRequestHeaders.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            await http.PostAsJsonAsync("api/shifts", new { shiftType = shiftType.ToString(), employeeId = 0 });
        }
        catch { /* Ignorer fejl — vagttype gemmes lokalt i UI */ }
        finally { isSavingShift = false; }
    }

    private async Task OnLogoutClick()
    {
        try { await JS.InvokeVoidAsync("localStorage.removeItem", "authToken"); } catch { }
        isLoggedIn = false;
        isAdmin = false;
        isVagtansvarlig = false;
        userDisplayName = "";
        selectedShiftType = null;
        loginEmail = "";
        pincode = "";
    }

    private async Task OnPincodeKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrEmpty(loginEmail) && pincode.Length >= 4 && !isLoggingIn)
            await OnLoginClick();
    }

    private Task OnEmailKeyUp(KeyboardEventArgs e) => Task.CompletedTask;

    // ── JWT afkodning (simpel, ingen bibliotek nødvendigt) ──
    private static List<System.Security.Claims.Claim> ParseClaimsFromJwt(string jwt)
    {
        var payload = jwt.Split('.')[1];
        var jsonBytes = ParseBase64WithoutPadding(payload);
        var keyValuePairs = JsonSerializer.Deserialize<Dictionary<string, object>>(jsonBytes);
        return keyValuePairs?.Select(kvp => new System.Security.Claims.Claim(kvp.Key, kvp.Value.ToString()!)).ToList() ?? new();
    }

    private static byte[] ParseBase64WithoutPadding(string base64)
    {
        switch (base64.Length % 4)
        {
            case 2: base64 += "=="; break;
            case 3: base64 += "="; break;
        }
        return Convert.FromBase64String(base64);
    }
}
