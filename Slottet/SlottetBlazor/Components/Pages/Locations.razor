@page "/Locations"
@using Domain.Enums
@rendermode InteractiveServer

<h1 class="mb-4">
    <i class="bi bi-geo-alt me-2" style="font-size: 32px;"></i>
    Lokationer
</h1>

<div class="row">

    <!-- VENSTRE: Lokationer -->
    <div class="col-md-4">

        <div class="list-group">

            @foreach (var location in LocationsList)
            {
                <button class="list-group-item list-group-item-action
                                   @(SelectedLocation?.LocationID == location.LocationID ? "active" : "")"
                        @onclick="() => SelectLocation(location)">

                    <strong>@location.Name</strong><br />
                    <small>@location.Address</small>
                </button>
            }

        </div>

        <button class="btn btn-outline-secondary mt-3 w-100"
                @onclick="AddLocationAsync">
            + Ny lokation
        </button>

    </div>

    <!-- HØJRE: Beboere -->
    <div class="col-md-8">

        @if (SelectedLocation != null)
        {
            <div class="card shadow-sm">
                <div class="card-header bg-white py-3">
                    <h4 class="mb-1">@SelectedLocation.Name</h4>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt-fill me-1"></i>
                        @SelectedLocation.Address, @SelectedLocation.ZipCode
                    </p>
                </div>

                <div class="card-body">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Navn</th>
                                    <th style="width: 120px;">Værelse</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var resident in SelectedLocation.Residents)
                                {
                                    <tr>
                                        <td style="width: 70%;">
                                            <div class="d-flex gap-2">
                                                <input class="form-control form-control-sm"
                                                       @bind="resident.FirstName" placeholder="Fornavn" />
                                                <input class="form-control form-control-sm"
                                                       @bind="resident.LastName" placeholder="Efternavn" />
                                            </div>
                                        </td>
                                        <td style="width: 30%;">
                                            <input class="form-control form-control-sm text-center"
                                                   @bind="resident.Room" />
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>

                <div class="card-footer bg-light d-flex justify-content-between align-items-center">
                    <button class="btn btn-sm btn-outline-secondary" @onclick="AddResidentAsync">
                        <i class="bi bi-plus-circle me-1"></i> Tilføj beboer
                    </button>
                    <button class="btn btn-primary" @onclick="SaveChangesAsync">
                        <i class="bi bi-check-lg me-1"></i> Gem ændringer
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="card bg-light border-dashed d-flex align-items-center justify-content-center" style="height: 200px; border: 2px dashed #dee2e6;">
                <p class="text-muted mb-0">Vælg en lokation til venstre for at se detaljer</p>
            </div>
        }

    </div>

</div>



@code {
    private List<Location> LocationsList = new();
    private int? selectedLocationId;

    private Location? SelectedLocation =>
        LocationsList.FirstOrDefault(l => l.LocationID == selectedLocationId);

    private void SelectLocation(Location location)
    {
        selectedLocationId = location.LocationID;
        StateHasChanged();
    }

    private string GetRiskClass(RiskLevel level) => level switch
    {
        RiskLevel.Green => "badge-risk-low",
        RiskLevel.Yellow => "badge-risk-mid",
        RiskLevel.Red => "badge-risk-high",
        _ => "bg-secondary"
    };

    private async Task AddLocationAsync() { }
    private async Task AddResidentAsync() { }
    private async Task SaveChangesAsync() { }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            LocationsList = new List<Location>
            {
                new Location
                {
                    LocationID = 1,
                    Name = "Afdeling A",
                    Address = "Slotsvej 1",
                    ZipCode = 8000,
                    Residents = new List<Resident>
                    {
                        new Resident { ResidentID = 1, FirstName = "Lars", LastName = "Andersen", Room = "101" },
                        new Resident { ResidentID = 2, FirstName = "Mette", LastName = "Hansen", Room = "102" },
                    }
                },
                new Location
                {
                    LocationID = 2,
                    Name = "Afdeling B",
                    Address = "Slotsvej 2",
                    ZipCode = 8000,
                    Residents = new List<Resident>
                    {
                        new Resident { ResidentID = 3, FirstName = "Jens", LastName = "Christensen", Room = "201" }
                    }
                }
            };
        }
        catch (HttpRequestException ex)
        {
            Debug.WriteLine(ex.Message);
        }

    }
}



