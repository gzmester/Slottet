@page "/Tasks"

<h1 class="mb-4 d-flex align-items-center">
    <i class="bi bi-list-task me-3 text-warning" style="font-size: 38px;"></i>
    <span class="fw-bold">Opgaver</span>
</h1>

<div class="row g-4">

    <!-- Særligt ansvarlige -->
    <div class="col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-header bg-warning-subtle border-0 rounded-top-4 py-3">
                <h4 class="mb-0 fw-semibold">
                    <i class="bi bi-person-check-fill me-2"></i>
                    Særligt ansvarlige
                </h4>
            </div>

            <div class="card-body p-0">

                <table class="table align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50%">Opgave</th>
                            <th>Navn</th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var task in specialTasks)
                        {
                            <tr>
                                <td>
                                    <input type="text"
                                           class="form-control rounded-3"
                                           placeholder="Opgave..."
                                           @bind="task.Title" />
                                </td>

                                <td>
                                    <input type="text"
                                           class="form-control rounded-3"
                                           placeholder="Navn..."
                                           @bind="task.Name" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>

            <!-- Knap under tabellen -->
            <div class="card-footer bg-white border-0 p-3">

                <button class="btn btn-warning rounded-3 w-100"
                        @onclick="AddSpecialTask">
                    <i class="bi bi-plus-lg me-2"></i>
                    Tilføj opgave
                </button>

            </div>

        </div>

    </div>

    <!-- Afdelingsopgaver -->
    <div class="col-lg-6">

        <div class="card shadow-sm border-0 rounded-4">

            <div class="card-header bg-warning-subtle border-0 rounded-top-4 py-3">
                <h4 class="mb-0 fw-semibold">
                    <i class="bi bi-building-fill-check me-2"></i>
                    Afdelingsopgaver
                </h4>
            </div>

            <div class="card-body">

                <div class="row g-3">

                    @foreach (var task in departmentTasks)
                    {
                        <div class="col-md-6">

                            <div class="border rounded-4 p-3 bg-light shadow-sm">

                                <input type="text"
                                       class="form-control rounded-3"
                                       placeholder="Skriv opgave..."
                                       @bind="task.Name" />

                            </div>

                        </div>
                    }

                </div>

            </div>

            <!-- Knap under rækkerne -->
            <div class="card-footer bg-white border-0 p-3">

                <button class="btn btn-warning rounded-3 w-100"
                        @onclick="AddDepartmentTask">
                    <i class="bi bi-plus-lg me-2"></i>
                    Tilføj opgave
                </button>

            </div>

        </div>

    </div>

</div>

@code {

    // Særligt ansvarlige
    private List<TaskItem> specialTasks = new()
    {
        new TaskItem { Title = "Medicinan­svarlig" },
        new TaskItem { Title = "Omsorgsperson" },
        new TaskItem { Title = "Frokost" },
        new TaskItem { Title = "Aftensmad" },
        new TaskItem { Title = "Hygiejne / afsprit" },
        new TaskItem { Title = "Ventil-tid" },
        new TaskItem { Title = "Rengøring af depot mandag før kl.14:00" },
        new TaskItem { Title = "Oprydning på kontor tirsdag før kl.14:00" }
    };

    // Afdelingsopgaver
    private List<TaskItem> departmentTasks = new()
    {
        new TaskItem { Name = "Fylde handsker op" },
        new TaskItem { Name = "Tømme opvaskemaskine" },
        new TaskItem { Name = "Rydde fællesrum" },
        new TaskItem { Name = "Kontrollere lager" }
    };

    // Tilføj særligt ansvarlig opgave
    private void AddSpecialTask()
    {
        specialTasks.Add(new TaskItem());
    }

    // Tilføj afdelingsopgave
    private void AddDepartmentTask()
    {
        departmentTasks.Add(new TaskItem());
    }

    public class TaskItem
    {
        public string Title { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
    }
}