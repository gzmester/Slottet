@page "/Employees"
@rendermode InteractiveServer
@using Application.DTOs.Employee
@using Application.DTOs.Location
@using Application.DTOs.Authorization
@inject IHttpClientFactory HttpClientFactory

@*Overskrift med ikon*@
<h1>
    <img src="images/icons/Employee.svg" style="width: 32px; height: 32px;"  />
    Ansatte
</h1>

@*Tabel som viser ansatte med navn, tlf, pinkode og rettigheder, samt en slet knap*@
<table class="table table-striped">
    <thead>
        <tr>
            <th>Navn</th>
            <th>Telefonnummer</th>
            <th>Pinkode</th>
            <th>Rettigheder</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @*Itererer gennem listen af ansatte og bruger informationerne til at vise dem i tabellen*@
        @foreach(var employee in employees)
        {
            <tr>
                <td>@employee.FirstName @employee.LastName</td>
                <td>@employee.PhoneNumber</td>
                <td>@employee.PinCode</td>
                <td>@string.Join(", ", employee.Roles)</td>
                <td><button class="btn btn-danger" @onclick="() => DeleteEmployeeAsync(employee)">Slet</button></td>
            </tr>
        }
    </tbody>
</table>
@*Tilføj medarbejder knap*@
<button class="btn btn-primary" @onclick="AddEmployeeAsync">+ Tilføj Ansat</button>

@* Modal til at tilføje en ny ansat *@
@*showModal bliver true når bruger trykker på "tilføj ansat" knappen, og derefter vises modalen*@
@*Modalen er bygget op efter bootsraps dokumentations eksempel*@
@if(showModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tilføj Ansat</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseModal()" aria-label="Close"></button>
                </div>
                @* Formular til at tilføje en ny ansat 
                Hvor hvert felt har en inputfelt
                mb-3 er afstnanden mellem hvert felt
                form-label giver skriftstørrelse til label
                form-control giver inputfeltet en bestemt størrelse og stil*@
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Fornavn</label>
                        <input type="text" maxlength="30" class="form-control" @bind="newFirstName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Efternavn</label>
                        <input type="text" maxlength="30" class="form-control" @bind="newLastName" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">E-mail</label>
                        <input type="email" maxlength="45" class="form-control" @bind="newEmail" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Telefonnummer</label>
                        <input type="tel" maxlength="8" class="form-control" @bind="newPhoneNumber" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Pinkode</label>
                        <input type="password" maxlength="6" class="form-control" @bind="newPinCode" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Lokation</label>
                        <select class="form-select" @bind="newLocationID">
                            <option value="0">Vælg lokation</option>
                            @foreach (var loc in locations)
                            {
                                <option value="@loc.LocationID">@loc.Name</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Autorisation</label>
                        <select class="form-select" @bind="newAuthorizationID">
                            <option value="0">Vælg autorisation</option>
                            @foreach (var auth in authorizations)
                            {
                                <option value="@auth.AuthorizationID">@(auth.Admin ? "Admin" : auth.Scheduler ? "Planlægger" : auth.Employee ? "Medarbejder" : "Vikar")</option>
                            }
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vagttype</label>
                        <select class="form-select" @bind="newShiftType">
                            <option value="">Vælg vagttype</option>
                            <option value="Day">Dag</option>
                            <option value="Midday">Middag</option>
                            <option value="Night">Nat</option>
                        </select>
                    </div>
                    @if (saveError is not null)
                    {
                        <div class="alert alert-danger">@saveError</div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => CloseModal()">Luk</button>
                    <button type="button" class="btn btn-primary" @onclick="SaveEmployeeAsync">Gem</button>
                </div>
            </div>
        </div>
    </div>
    @*Gør baggrunden mørkere mens modalen er åben, så man kan skelne mellem baggrunden og modalen*@
    <div class="modal-backdrop fade show"></div>
}


@code {
    private bool showModal = false;

    private string newFirstName = string.Empty;
    private string newLastName = string.Empty;
    private string newEmail = string.Empty;
    private string newPhoneNumber = string.Empty;
    private string newPinCode = string.Empty;
    private int newLocationID;
    private int newAuthorizationID;
    private string newShiftType = string.Empty;
    private string? saveError;

    private List<EmployeeResponseDto> employees = new();
    private List<LocationResponseDto> locations = new();
    private List<AuthorizationResponseDto> authorizations = new();

    protected override async Task OnInitializedAsync()
    {
        var http = HttpClientFactory.CreateClient("API");

        var empTask  = http.GetFromJsonAsync<List<EmployeeResponseDto>>("api/employees");
        var locTask  = http.GetFromJsonAsync<List<LocationResponseDto>>("api/locations");
        var authTask = http.GetFromJsonAsync<List<AuthorizationResponseDto>>("api/authorizations");

        await Task.WhenAll(empTask, locTask, authTask);

        if (empTask.Result  is not null) employees      = empTask.Result;
        if (locTask.Result  is not null) locations      = locTask.Result;
        if (authTask.Result is not null) authorizations = authTask.Result;
    }

    private void AddEmployeeAsync()
    {
        newFirstName = string.Empty;
        newLastName = string.Empty;
        newEmail = string.Empty;
        newPhoneNumber = string.Empty;
        newPinCode = string.Empty;
        newLocationID = 0;
        newAuthorizationID = 0;
        newShiftType = string.Empty;
        saveError = null;
        showModal = true;
    }

    private async Task SaveEmployeeAsync()
    {
        saveError = null;

        if (!int.TryParse(newPhoneNumber, out var phone))
        {
            saveError = "Telefonnummer skal være et tal.";
            return;
        }
        if (!int.TryParse(newPinCode, out var pin))
        {
            saveError = "Pinkode skal være et tal.";
            return;
        }
        if (newLocationID == 0 || newAuthorizationID == 0 || string.IsNullOrEmpty(newShiftType))
        {
            saveError = "Udfyld venligst alle felter.";
            return;
        }

        var dto = new EmployeeCreateDto
        {
            FirstName       = newFirstName,
            LastName        = newLastName,
            Email           = newEmail,
            PhoneNumber     = newPhoneNumber,
            PinCode         = pin,
            LocationID      = newLocationID,
            AuthorizationID = newAuthorizationID,
            ShiftType       = newShiftType
        };

        var http = HttpClientFactory.CreateClient("API");
        var response = await http.PostAsJsonAsync("api/employees", dto);

        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<EmployeeResponseDto>();
            if (created is not null)
                employees.Add(created);
            CloseModal();
        }
        else
        {
            saveError = $"Fejl ved oprettelse: {response.StatusCode}";
        }
    }

    private async Task DeleteEmployeeAsync(EmployeeResponseDto employee)
    {
        var http = HttpClientFactory.CreateClient("API");
        var response = await http.DeleteAsync($"api/employees/{employee.Id}");
        if (response.IsSuccessStatusCode)
            employees.Remove(employee);
    }

    private void CloseModal()
    {
        showModal = false;
    }
}
