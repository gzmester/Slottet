@page "/PhoneNumbers"
@rendermode InteractiveServer
@using Application.DTOs.PhoneNumber
@using System.Diagnostics

@inject IHttpClientFactory HttpClientFactory

<h1 class="mb-4">
    <i class="bi bi-telephone-fill me-2" style="font-size: 32px;"></i>
    Arbejdstelefoner
</h1>

@if (saveError)
{
    <div class="alert alert-danger">
        Noget gik galt — prøv igen.
    </div>
}

<div class="card shadow-sm">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h5 class="mb-0 fw-semibold">Telefonnumre</h5>
        <button class="btn btn-sm btn-outline-primary" @onclick="() => AddPhoneNumberAsync()">
            <i class="bi bi-plus-lg me-1"></i> Tilføj nummer
        </button>
    </div>

    <div class="card-body p-0">
        @if (!phoneNumbers.Any())
        {
            <p class="text-muted fst-italic p-4 mb-0">Ingen telefonnumre registreret.</p>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 50%">Nummer</th>
                            <th style="width: 50%">Tildelt til</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var phoneNumber in phoneNumbers)
                        {
                            <tr class="@(selectedPhone?.Id == phoneNumber.Id ? "table-active" : "")"
                                style="cursor: pointer;"
                                @onclick="() => selectedPhone = phoneNumber">
                                <td><strong>@phoneNumber.Number</strong></td>
                                <td @onclick:stopPropagation>
                                    <input type="text"
                                           class="form-control form-control-sm"
                                           @bind="phoneNumber.AssignedTo"
                                           placeholder="Angiv navn" />
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="card-footer bg-white py-3 d-flex justify-content-between align-items-center">
        <span class="text-muted small">
            @if (selectedPhone != null)
            {
                <span>Valgt: <strong>@selectedPhone.Number</strong></span>
            }
            else
            {
                <span>Vælg et nummer i listen</span>
            }
        </span>
        <div class="d-flex gap-2">
            <button class="btn btn-sm btn-outline-danger"
                    disabled="@(selectedPhone == null)"
                    @onclick="DeleteSelected">
                <i class="bi bi-trash me-1"></i>Slet
            </button>
            <button class="btn btn-sm btn-outline-secondary"
                    disabled="@(selectedPhone == null)"
                    @onclick="EditSelected">
                <i class="bi bi-pencil me-1"></i>Rediger
            </button>
            <button class="btn btn-sm btn-outline-primary"
                    disabled="@(selectedPhone == null)"
                    @onclick="SaveSelected">
                <i class="bi bi-check-lg me-1"></i>Gem
            </button>
        </div>
    </div>
</div>

@if (showAddModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Tilføj nummer</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseModal()" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nummer</label>
                        <input type="text" class="form-control" @bind="newNumber" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => CloseModal()">Luk</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmAddAsync">Gem</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@if (showEditModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Rediger nummer</h5>
                    <button type="button" class="btn-close" @onclick="() => CloseModal()" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Nyt nummer</label>
                        <input type="text" class="form-control" @bind="newNumber" placeholder="@editingPhone?.Number" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => CloseModal()">Luk</button>
                    <button type="button" class="btn btn-primary" @onclick="ConfirmEditAsync">Gem</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    private bool saveError = false;
    private bool showAddModal = false;
    private bool showEditModal = false;
    private string newNumber = string.Empty;
    private PhoneNumberResponseDto? editingPhone = null;
    private PhoneNumberResponseDto? selectedPhone = null;
    private List<PhoneNumberResponseDto> phoneNumbers = new List<PhoneNumberResponseDto>();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("API");
            var result = await http.GetFromJsonAsync<List<PhoneNumberResponseDto>>("api/phoneNumber");

            if (result is not null)
                phoneNumbers = result;
        }
        catch (HttpRequestException ex)
        {
            errorMessage = ex.Message;
            showError = true;
            Debug.WriteLine(ex.Message);
        }
    }

    private async Task SaveSelected()
    {
        if (selectedPhone is not null)
            await SaveAssignmentAsync(selectedPhone);
    }

    private async Task EditSelected()
    {
        if (selectedPhone is not null)
            await EditPhoneNumberAsync(selectedPhone);
    }

    private async Task DeleteSelected()
    {
        if (selectedPhone is not null)
            await DeletePhoneNumberAsync(selectedPhone);
    }

    private async Task SaveAssignmentAsync(PhoneNumberResponseDto phoneNumber)
    {
        saveError = false;
        var http = HttpClientFactory.CreateClient("API");
        var response = await http.PatchAsJsonAsync($"api/phoneNumber/{phoneNumber.Id}/assignment", phoneNumber.AssignedTo);

        if (!response.IsSuccessStatusCode)
            saveError = true;
    }

    private async Task AddPhoneNumberAsync()
    {
        showAddModal = true;
    }

    private async Task ConfirmAddAsync()
    {
        saveError = false;
        var http = HttpClientFactory.CreateClient("API");
        var dto = new PhoneNumberCreateDto { Number = newNumber };
        var response = await http.PostAsJsonAsync("api/phoneNumber", dto);

        if (response.IsSuccessStatusCode)
        {
            var created = await response.Content.ReadFromJsonAsync<PhoneNumberResponseDto>();
            if (created is not null) phoneNumbers.Add(created);
            showAddModal = false;
            newNumber = string.Empty;
        }
        else
        {
            saveError = true;
        }
    }

    private async Task EditPhoneNumberAsync(PhoneNumberResponseDto phoneNumber)
    {
        editingPhone = phoneNumber;
        showEditModal = true;
    }

    private async Task ConfirmEditAsync()
    {
        saveError = false;
        if (editingPhone is null) return;

        var http = HttpClientFactory.CreateClient("API");
        var dto = new PhoneNumberUpdateDto { Number = newNumber };
        var response = await http.PutAsJsonAsync($"api/phoneNumber/{editingPhone.Id}", dto);

        if (response.IsSuccessStatusCode)
        {
            editingPhone.Number = newNumber;
            showEditModal = false;
            newNumber = string.Empty;
            editingPhone = null;
        }
        else
        {
            saveError = true;
        }
    }

    private async Task DeletePhoneNumberAsync(PhoneNumberResponseDto phoneNumber)
    {
        saveError = false;
        var http = HttpClientFactory.CreateClient("API");
        var response = await http.DeleteAsync($"api/phoneNumber/{phoneNumber.Id}");

        if (response.IsSuccessStatusCode)
        {
            phoneNumbers.Remove(phoneNumber);
            if (selectedPhone?.Id == phoneNumber.Id)
                selectedPhone = null;
        }
        else
        {
            saveError = true;
        }
    }

    private void CloseModal()
    {
        showAddModal = false;
        showEditModal = false;
    }
}

<ErrorModal IsVisible="@showError"
            ErrorMessage="@errorMessage"
            OnClose="@(() => showError = false)" />
@code {
    private bool showError = false;
    private string? errorMessage;
}
