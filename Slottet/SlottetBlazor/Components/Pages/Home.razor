@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div class="residents-container">
    <div class="residents-grid">
        @for (int i = 0; i < ResidentsPerPage && (CurrentPage - 1) * ResidentsPerPage + i < TotalResidents; i++)
        {
            <ResidentCard/>
        }
    </div>

    <div class="pagination">
        @for (int page = 1; page <= TotalPages; page++)
        {
            var pageNum = page;
            <button class="page-button @(CurrentPage == pageNum ? "active" : "")"
                    @onclick="@( () => GoToPage(pageNum) )">
                @pageNum
            </button>
        }
    </div>
</div>

@code {
    private int CurrentPage = 1;
    private int ResidentsPerPage = 6;
    private int TotalResidents = 18;

    private int TotalPages => (int)Math.Ceiling((double)TotalResidents / ResidentsPerPage);

    private void GoToPage(int page)
    {
        if (page >= 1 && page <= TotalPages)
        {
            CurrentPage = page;
        }
    }
}