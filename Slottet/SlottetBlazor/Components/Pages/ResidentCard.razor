<div class="resident-card-container">
    <table class="resident-header-table">
        <tr>
            <th class="@GetRiskClass()">Navn</th>
            <th class="@GetRiskClass()">Værelses Nr.</th>
        </tr>
        <tr>
            <td>
                <select class="dropdown-risk-input @GetRiskClass()" @onchange="OnRiskLevelChange">
                    <option value="">Risiko</option>
                    <option value="low">Lav Risiko</option>
                    <option value="medium">Medium Risiko</option>
                    <option value="high">Høj Risiko</option>
                </select>
            </td>
            <td>
                <select class="dropdown-mood-input">
                    <option value="">Humør </option>
                    <option value="sad">Trist 🙁</option>
                    <option value="neutral">Neutral 😑</option>
                    <option value="happy">Glad 🙂</option>
                </select>
            </td>
        </tr>
    </table>

    
    <table class="resident-middle-table">
        <tr>
            <td>Medicin</td>
            <td>
                <div class="flex-container">
                 <input type="time" class="table-input " /> 
                 <input type="checkbox" class="checkbox-input " />
                </div>
            </td>
            <td>
                <div class="flex-container">
                 <input type="time" class="table-input " /> 
                 <input type="checkbox" class="checkbox-input" />
                </div>
            </td>
            <td>
                <div class="flex-container">
                 <input type="time" class="table-input" /> 
                 <input type="checkbox" class="checkbox-input" />
                </div>
            </td>
            <td>
                <div class="flex-container">
                 <input type="time" class="table-input" /> 
                 <input type="checkbox" class="checkbox-input" />
                </div>
            </td>
        </tr>
        <tr>
            <td>PN-tid</td>
            <td><textarea class="table-input "></textarea></td>
            <td><textarea class="table-input "></textarea></td>
            <td><textarea class="table-input "></textarea></td>
            <td><textarea class="table-input "></textarea></td>
        </tr>
    </table>
    


    <table class="resident-bottom-table">
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>HandleDag</strong></td>
            <td><input type="text" class="table-input" placeholder="eks. Torsdag formiddag, Handler ofte selv"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>Betaling</strong></td>
            <td><input type="text" class="table-input" placeholder="eks. Eget kort, Kontant fra kontor: 400,-"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>Status</strong></td>
            <td><textarea rows="3" class="table-input"></textarea></td>
        </tr>
    </table>
</div>

@code {
    private string selectedRiskLevel = "";

    private void OnRiskLevelChange(ChangeEventArgs e)
    {
        selectedRiskLevel = e.Value?.ToString() ?? "";
    }

    private string GetRiskClass()
    {
        return selectedRiskLevel switch
        {
            "low" => "risk-low",
            "medium" => "risk-medium",
            "high" => "risk-high",
            _ => ""
        };
    }
}