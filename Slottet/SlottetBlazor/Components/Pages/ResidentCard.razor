@using Application.DTOs.Resident
@inject IHttpClientFactory HttpClientFactory
<div class="resident-card-container">
    <table class="resident-header-table">
        <tr>
            <th class="@GetRiskClass()">@FirstName @LastName</th>
            <th class="@GetRiskClass()"> Rum @Room</th>
        </tr>
        <tr>
            <td>
                <select class="dropdown-risk-input @GetRiskClass()" @onchange="OnRiskLevelChange">
                    <option value=""> Risiko </option>
                    <option value="Green" selected="@(RiskLevel == "Green")">Lav Risiko</option>
                    <option value="Yellow" selected="@(RiskLevel == "Yellow")">Medium Risiko</option>
                    <option value="Red" selected="@(RiskLevel == "Red")">Høj Risiko</option>
                </select>
            </td>
            <td>
                <select class="dropdown-mood-input" value="@Mood" @onchange="OnMoodChange">
                    <option value="">Humør </option>
                    <option value="Sad">Trist 🙁</option>
                    <option value="Neutral">Neutral 😑</option>
                    <option value="Happy">Glad 🙂</option>
                </select>
            </td>
        </tr>
    </table>

    @* Medicin & PN Table *@
    <table class="resident-middle-table">
        <tr>
            <td>Medicin</td>
            @for (int i = 0; i < 4; i++)
            {
                var med = _sortedMedicins.Count > i ? _sortedMedicins[i] : null;
                <td>
                    <div class="flex-container">
                        @if (med != null)
                        {
                            <input type="time" class="table-input" value="@med.Time.ToString("HH:mm")" @onchange="(ChangeEventArgs e) => OnTimeInputChange(med, e)" />
                            <input type="checkbox" class="checkbox-input" checked="@med.IsTaken" @onchange="() => ToggleIsTakenAsync(med)" />
                        }
                        else
                        {
                            <input type="time" class="table-input" disabled />
                            <input type="checkbox" class="checkbox-input" disabled />
                        }
                    </div>
                </td>
            }
        </tr>
        <tr>
            <td>PN-tid</td>

                <td><textarea class="table-input" rows="1"></textarea>
                    <input type="time" class="table-input" /></td>
                
                <td><textarea class="table-input" rows="1"></textarea>
                    <input type="time" class="table-input" /></td>
                
                <td><textarea class="table-input" rows="1"></textarea>
                    <input type="time" class="table-input" /></td>
                
                <td><textarea class="table-input" rows="1"></textarea>
                    <input type="time" class="table-input" /></td>

        </tr>
    </table>
    

    @* HandleDag, Betaling & Status*@
    <table class="resident-bottom-table">
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>HandleDag</strong></td>
            <td><input type="text" class="table-input" @bind="ShoppingDay" @bind:event="oninput" @onchange="SaveChanges" placeholder="eks. Torsdag formiddag, Handler ofte selv"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>Betaling</strong></td>
            <td><input type="text" class="table-input" @bind="Payment" @bind:event="oninput" @onchange="SaveChanges" placeholder="eks. Eget kort, Kontant fra kontor: 400,-"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%; vertical-align: top;">
                <div class="d-flex flex-column align-items-start">
                    <strong>Status</strong>
                    @if (_displayStatuses.Count > 1)
                    {
                        <button class="btn btn-link btn-sm p-0" @onclick="() => _showStatusModal = true">
                            Se alle (@_displayStatuses.Count)
                        </button>
                    }
                </div>
            </td>
            
            <td>

                <textarea rows="1" maxlength="200" class="table-input" @bind="Status" @bind:event="oninput" @onchange="SaveChanges" placeholder="Tilføj status... (max 200 tegn)"></textarea>

                @foreach (var s in _displayStatuses.Take(1))
                {
                    <div class="status-entry"><span class="text-muted small">@s.Time.ToString("HH:mm")</span> @s.Description</div>
                }

                
            </td>
        </tr>
    </table>
</div>

@if (_showStatusModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Statuser idag — @FirstName @LastName</h5>
                    <button type="button" class="btn-close" @onclick="() => _showStatusModal = false"></button>
                </div>
                <div class="modal-body">
                    @foreach (var s in _displayStatuses)
                    {
                        <div class="mb-2">
                            <span class="badge bg-secondary">@s.Time.ToString("HH:mm")</span>
                            <span class="ms-2">@s.Description</span>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showStatusModal = false">Luk</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int ResidentID { get; set; }

    [Parameter]
    public string FirstName { get; set; } = string.Empty;

    [Parameter]
    public string LastName { get; set; } = string.Empty;

    [Parameter]
    public string Room { get; set; } = string.Empty;

    [Parameter]
    public string RiskLevel { get; set; } = string.Empty;

    [Parameter]
    public string Mood { get; set; } = "Neutral";

    [Parameter]
    public string ShoppingDay { get; set; } = string.Empty;

    [Parameter]
    public string Payment { get; set; } = string.Empty;

    [Parameter]
    public List<MedicinDto> Medicins { get; set; } = new();

    [Parameter]
    public List<string> PNMedicins { get; set; } = new();

    [Parameter]
    public List<StatusDto> Statuses { get; set; } = new();

    private string Status = string.Empty;
    private List<StatusDto> _displayStatuses = new();
    private bool _showStatusModal = false;
    private List<MedicinDto> _sortedMedicins = new();

    protected override void OnParametersSet()
    {
        _displayStatuses = Statuses.ToList();
        // Sort medicines by time of day and take first 4
        _sortedMedicins = Medicins
            .OrderBy(m => m.Time.TimeOfDay)
            .Take(4)
            .ToList();
    }

    private async Task SaveChanges()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("API");

            var updateRequest = new
            {
                ResidentID,
                FirstName,
                LastName,
                Room,
                RiskLevel,
                Mood,
                ShoppingDay,
                Payment,
                Status = Status
            };

            var response = await http.PutAsJsonAsync($"api/resident/{ResidentID}", updateRequest);

            if (response.IsSuccessStatusCode && !string.IsNullOrWhiteSpace(Status))
            {
                _displayStatuses.Insert(0, new StatusDto { Description = Status, Time = DateTime.Now });
                Status = string.Empty;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex}");
        }
    }

    private async Task ToggleIsTakenAsync(MedicinDto med)
    {
        med.IsTaken = !med.IsTaken;
        var http = HttpClientFactory.CreateClient("API");
        await http.PatchAsync($"api/medicin/{med.MedicinID}/taken?isTaken={med.IsTaken}", null);
    }

    private async Task OnTimeInputChange(MedicinDto med, ChangeEventArgs e)
    {
        if (e.Value is string timeString && !string.IsNullOrEmpty(timeString))
        {
            // Parse the time string (HH:mm format from the time input)
            if (TimeSpan.TryParse(timeString, out var timeSpan))
            {
                // Update the medicine's time while keeping the date part
                med.Time = med.Time.Date.Add(timeSpan);
                
                var http = HttpClientFactory.CreateClient("API");
                try
                {
                    // Send PUT request to update the medicine time
                    await http.PutAsJsonAsync($"api/medicin/{med.MedicinID}", new { Time = med.Time });
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error updating medicine time: {ex}");
                }
            }
        }
    }

    private void OnRiskLevelChange(ChangeEventArgs e)
    {
        RiskLevel = e.Value?.ToString() ?? "";
        _ = SaveChanges();
    }

    private void OnMoodChange(ChangeEventArgs e)
    {
        Mood = e.Value?.ToString() ?? "Neutral";
        _ = SaveChanges();
    }

    private string GetRiskClass() => RiskLevel switch
    {
        "Green"  => "risk-low",
        "Yellow" => "risk-medium",
        "Red"    => "risk-high",
        _        => ""
    };
}