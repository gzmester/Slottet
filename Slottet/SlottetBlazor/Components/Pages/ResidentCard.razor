@using Application.DTOs.Resident
@inject IHttpClientFactory HttpClientFactory
<div class="resident-card-container @(!IsLoggedIn ? "card-readonly" : "")">
    <table class="resident-header-table">
        <tr>
            <th class="@GetRiskClass()">@FirstName @LastName</th>
            <th class="@GetRiskClass()"> Rum @Room</th>
        </tr>
        <tr>
            <td>
                <select class="dropdown-risk-input @GetRiskClass()" @onchange="OnRiskLevelChange" disabled="@(!IsLoggedIn)">
                    <option value=""> Risiko </option>
                    <option value="Green" selected="@(RiskLevel == "Green")">Lav Risiko</option>
                    <option value="Yellow" selected="@(RiskLevel == "Yellow")">Medium Risiko</option>
                    <option value="Red" selected="@(RiskLevel == "Red")">Høj Risiko</option>
                </select>
            </td>
            <td>
                <select class="dropdown-mood-input" value="@Mood" @onchange="OnMoodChange" disabled="@(!IsLoggedIn)">
                    <option value="">Humør </option>
                    <option value="Sad">Trist 🙁</option>
                    <option value="Neutral">Neutral 😑</option>
                    <option value="Happy">Glad 🙂</option>
                </select>
            </td>
        </tr>
    </table>

    @* Medicin & PN Table *@
    <table class="resident-middle-table">
        <tr>
            <td>Medicin</td>
            @for (int i = 0; i < 4; i++)
            {
                var med = _sortedMedicins.Count > i ? _sortedMedicins[i] : null;
                <td>
                    <div class="d-flex flex-column ">
                        @*Hvis medicin findes vises typen og tid og checkboks*@
                        @if (med != null)
                        {
                            <input type="text" class="table-input" value="@med.Type" disabled />
                            <div class="d-flex gap-1">
                                <input type="time" class="table-input" value="@med.Time.ToString("HH:mm")" @onchange="(ChangeEventArgs e) => OnTimeInputChange(med, e)" disabled="@(!IsLoggedIn)" />
                                <input type="checkbox" class="checkbox-input" checked="@med.IsTaken" @onchange="() => ToggleIsTakenAsync(med)" disabled="@(!IsLoggedIn)" />
                            </div>
                        }
                        else
                        {
                            <input type="time" class="table-input" disabled />
                            <input type="checkbox" class="checkbox-input" disabled />
                        }
                    </div>
                </td>
            }
        </tr>
        <tr>
            <td>PN-tid</td>
            @*Pn tider der vises i 4 kolonner. Hvis der er indtastet en tid, skal typen angives og gemmes*@
                @for (int i = 0; i < 4; i++)
                {
                    var index = i;
                    <td>
                        <div class="d-flex flex-column">
                            <input type="time" class="table-input" 
                                value="@pnTimes[index]"
                                @onchange="(ChangeEventArgs e) => OnPNTimeSelected(index, e)"
                                disabled="@(!IsLoggedIn)" />
                            @if (pnShowType[index])
                            {
                                <input type="text" class="table-input" 
                                    placeholder="Hvad blev givet?"
                                    value="@pnTypes[index]"
                                    @onchange="(ChangeEventArgs e) => OnPNTypeChange(index, e)" />
                            }
                        </div>
                    </td>
                }
        </tr>
    </table>
    

    @* HandleDag, Betaling & Status*@
    <table class="resident-bottom-table">
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>HandleDag</strong></td>
            <td><input type="text" class="table-input" @bind="ShoppingDay" @bind:event="oninput" @onchange="SaveChanges" placeholder="eks. Torsdag formiddag, Handler ofte selv" disabled="@(!IsLoggedIn)"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%;"><strong>Betaling</strong></td>
            <td><input type="text" class="table-input" @bind="Payment" @bind:event="oninput" @onchange="SaveChanges" placeholder="eks. Eget kort, Kontant fra kontor: 400,-" disabled="@(!IsLoggedIn)"/></td>
        </tr>
        <tr>
            <td class="text-nowrap" style="width: 1%; vertical-align: top;">
                <div class="d-flex flex-column align-items-start">
                    <strong>Status</strong>
                    @if (_displayStatuses.Count > 1)
                    {
                        <button class="btn btn-link btn-sm p-0" @onclick="() => _showStatusModal = true">
                            Se alle (@_displayStatuses.Count)
                        </button>
                    }
                </div>
            </td>
            
            <td>

                <textarea rows="1" maxlength="200" class="table-input" @bind="Status" @bind:event="oninput" @onchange="SaveChanges" placeholder="Tilføj status... (max 200 tegn)" disabled="@(!IsLoggedIn)"></textarea>

                @foreach (var s in _displayStatuses.Take(1))
                {
                    <div class="status-entry"><span class="text-muted small">@s.Time.ToString("HH:mm")</span> @s.Description</div>
                }

                
            </td>
        </tr>
    </table>
</div>

@if (_showStatusModal)
{
    <div class="modal d-block" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Statuser idag — @FirstName @LastName</h5>
                    <button type="button" class="btn-close" @onclick="() => _showStatusModal = false"></button>
                </div>
                <div class="modal-body">
                    @foreach (var s in _displayStatuses)
                    {
                        <div class="mb-2">
                            <span class="badge bg-secondary">@s.Time.ToString("HH:mm")</span>
                            <span class="ms-2">@s.Description</span>
                        </div>
                    }
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" @onclick="() => _showStatusModal = false">Luk</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-backdrop fade show"></div>
}

@code {
    [Parameter]
    public int ResidentID { get; set; }

    [Parameter]
    public bool IsLoggedIn { get; set; } = false;

    [Parameter]
    public string FirstName { get; set; } = string.Empty;

    [Parameter]
    public string LastName { get; set; } = string.Empty;

    [Parameter]
    public string Room { get; set; } = string.Empty;

    [Parameter]
    public string RiskLevel { get; set; } = string.Empty;

    [Parameter]
    public string Mood { get; set; } = "Neutral";

    [Parameter]
    public string ShoppingDay { get; set; } = string.Empty;

    [Parameter]
    public string Payment { get; set; } = string.Empty;

    [Parameter]
    public List<MedicinDto> Medicins { get; set; } = new();

    [Parameter]
    public List<StatusDto> Statuses { get; set; } = new();
    [Parameter]
    public List<PNMedicinResponseDto> PNMedicins { get; set; } = new();

    private string Status = string.Empty;
    private List<StatusDto> _displayStatuses = new();
    private bool _showStatusModal = false;
    private List<MedicinDto> _sortedMedicins = new();
    
    
    //array som bruges til at holde styr på de 4 pn tider og typer, bruges til som en mellemstation der holde r data indtil brugeren er færdig med at udfylde både tidspunkt og type
    //PnTimes bruges til at holde styr på de indtastede tider for pn medicinen
    private string[] pnTimes = new string[4];
    //PnTypes bruges til at holde styr på de indtastede typer for pn medicinen
    private string[] pnTypes = new string[4];
    //pnShowType bruges til at holde styr på om typen for pn medicinen skal vises, da den kun skal vises hvis der er indtastet en tid
    private bool[] pnShowType = new bool[4];
    //pnIds bruges til at holde styr på hvilke pn medicin der allerede findes i databasen, så vi ved om vi skal lave en POST eller en PUT når der ændres i tid eller type
    private int?[] pnIds = new int?[4];
   

    //OnParametersSet kører hver gang der kommer nye parametre ind i komponenten, og her sorteres medicins og pn medicins og de 4 første af hver tages, og pn tider og typer gemmes i arrays
    //fx når siden indlæses første gang, eller når der kommer nye data ind efter en opdatering
    protected override void OnParametersSet()
    {
        _displayStatuses = Statuses.ToList();
        // Sort medicines by time of day and take first 4
        _sortedMedicins = Medicins
            .OrderBy(m => m.Time.TimeOfDay)
            .Take(4)
            .ToList();

        //sorter pn medicin efter tid og tag de første 4
        var todaysPNMedicins = PNMedicins
            .Where(pn => pn.Time.Date == DateTime.Today)
            .OrderBy(pn => pn.Time)
            .Take(4)
            .ToList();

        //gem pn tider og typer i arrays, og sæt pnShowType til true for de pn mediciner der har en tid, så typen kan vises
        for (int i = 0; i < todaysPNMedicins.Count; i++)
        {
            pnTimes[i] = todaysPNMedicins[i].Time.ToString("HH:mm");
            pnTypes[i] = todaysPNMedicins[i].Type;
            pnShowType[i] = true;
            pnIds[i] = todaysPNMedicins[i].PNMedicinID;
        }
    }

    private async Task SaveChanges()
    {
        try
        {
            var http = HttpClientFactory.CreateClient("API");

            var updateRequest = new
            {
                ResidentID,
                FirstName,
                LastName,
                Room,
                RiskLevel,
                Mood,
                ShoppingDay,
                Payment,
                Status = Status
            };

            var response = await http.PutAsJsonAsync($"api/resident/{ResidentID}", updateRequest);

            if (response.IsSuccessStatusCode && !string.IsNullOrWhiteSpace(Status))
            {
                _displayStatuses.Insert(0, new StatusDto { Description = Status, Time = DateTime.Now });
                Status = string.Empty;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex}");
        }
    }

    private async Task ToggleIsTakenAsync(MedicinDto med)
    {
        med.IsTaken = !med.IsTaken;
        var http = HttpClientFactory.CreateClient("API");
        await http.PatchAsync($"api/medicin/{med.MedicinID}/taken?isTaken={med.IsTaken}", null);
    }

    private async Task OnTimeInputChange(MedicinDto med, ChangeEventArgs e)
    {
        if (e.Value is string timeString && !string.IsNullOrEmpty(timeString))
        {
            // Parse the time string (HH:mm format from the time input)
            if (TimeSpan.TryParse(timeString, out var timeSpan))
            {
                // Update the medicine's time while keeping the date part
                med.Time = med.Time.Date.Add(timeSpan);
                
                var http = HttpClientFactory.CreateClient("API");
                try
                {
                    // Send PUT request to update the medicine time
                    await http.PutAsJsonAsync($"api/medicin/{med.MedicinID}", new { Time = med.Time });
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"Error updating medicine time: {ex}");
                }
            }
        }
    }

    //Når en pn tid vælges eller ændres, opdateres pntime arrayet og pnshowtype sættes til true for at vise type inputtet
    //Hvis tiden fjernes, sættes pnshowtype til false for at skjule type inputtet
    private async Task OnPNTimeSelected(int index, ChangeEventArgs e)
    {
        if (e.Value is string timeString && !string.IsNullOrEmpty(timeString))
        {
            pnTimes[index] = timeString;
            pnShowType[index] = true;
        }
        else
        {
            pnShowType[index] = false;
        }
    }

    //Når en pn type angives eller ændres, opdateres pntype arrayet, og hvis der allerede er en tid for det nuværende index
    //Sendes enten en POST resquest for at oprette en ny pn medicin, eller en PUT request for at opdatere den eksisterende pn medicin
    //Afhængit af om der allerde findes en pn medicin i databasen for det nuværende index, som tjekkes via pnIds arrayet
    private async Task OnPNTypeChange(int index, ChangeEventArgs e)
    {
        //Opdater den indtastede type i arrayet
        pnTypes[index] = e.Value?.ToString() ?? string.Empty;
        
        //Hvis der ikke er indtastet en tid, skal typen ikke gemmes, og der skal ikke sendes nogen request til API'et, 
        //da en pn medicin uden tid ikke giver mening, så vi returnerer bare fra metoden
        if(string.IsNullOrWhiteSpace(pnTimes[index]))
        {
            return;
        }

        //Hvis der er indtastet en tid for det nuværende index, skal typen gemems, og der skal sendes en request ti lAPI'et for at gemme ændringen
        if(TimeSpan.TryParse(pnTimes[index], out var timeSpan))
        {
            //Beregn den fulde tid for pn medicinen ved at kombinere dagens dato med den indtastede tid
            var time = DateTime.Today.Add(timeSpan);

            //Hvis der allerede findes en pn medicin i databasen for det nuværende index,
            //skal den opdateres med den nye type og tid, ellers skal der oprettes en ny pn medicin med den indtastede type og tid
            var http = HttpClientFactory.CreateClient("API");
            if (pnIds[index].HasValue)
            {
                // PUT — opdater eksisterende
                await http.PutAsJsonAsync($"api/pnmedicin/{pnIds[index]}", new { Type = pnTypes[index], Time = DateTime.Today.Add(TimeSpan.Parse(pnTimes[index])) });
            }
            else
            {
                // POST — opret ny
                var response = await http.PostAsJsonAsync("api/pnmedicin", new PNMedicinCreateDto 
                    { 
                        Type = pnTypes[index], 
                        Time = DateTime.Today.Add(TimeSpan.Parse(pnTimes[index])),
                        ResidentId = ResidentID 
                    });
            }
        }
        
    }

    private void OnRiskLevelChange(ChangeEventArgs e)
    {
        RiskLevel = e.Value?.ToString() ?? "";
        _ = SaveChanges();
    }

    private void OnMoodChange(ChangeEventArgs e)
    {
        Mood = e.Value?.ToString() ?? "Neutral";
        _ = SaveChanges();
    }

    private string GetRiskClass() => RiskLevel switch
    {
        "Green"  => "risk-low",
        "Yellow" => "risk-medium",
        "Red"    => "risk-high",
        _        => ""
    };
}